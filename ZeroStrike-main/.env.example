# Zero Strike — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# Serveur HTTP / WebSocket
PORT=3000
HOST=0.0.0.0

# Display : `state_update` partiel (omit blocs JSON inchangés vs tick précédent). 0 / false = toujours full.
# DISPLAY_STATE_DELTA=0

# Socket.io : compression WebSocket (permessage-deflate, seuil 256 o). 0 / false = désactivé.
# SOCKET_COMPRESS=0

# Mot de passe du client « projecteur » (namespace /display). Vide ou absent = pas de garde (dev).
# Exemple soutenance / salle : empêche plusieurs onglets display sans le secret.
# DISPLAY_PASSWORD=mk_swish78

# Base de données SQLite (classement)
# Par défaut : data/leaderboard.db
# Utiliser :memory: pour les tests (pas de persistance)
# DB_PATH=data/leaderboard.db
# Délai (ms) avant écriture disque après mutations (réduit les fsync). 0 = immédiat.
# LEADERBOARD_SAVE_DEBOUNCE_MS=75

# Environnement (development | production)
# En production : CORS restreint, logs réduits
# NODE_ENV=production

# Origines CORS autorisées (Socket.io)
# Séparées par des virgules. En production sans cette variable,
# seules https://zerostrike.onrender.com est autorisée.
# Exemple : ALLOWED_ORIGINS=https://mon-domaine.com,https://www.mon-domaine.com

# Logs détaillés (input_move, etc.)
# DEBUG=1

# Traçabilité partie (JSON : display_connected, player_joined, round_phase…)
# — pas de noms / code partie ; uniquement round_state, socket_id, player_id, etc.
# GAME_TRACE=1

# Observabilité : logs JSON périodiques (TPS boucle, latence socket agrégée, sockets)
# Intervalle en ms (défaut 15000). Désactiver les logs périodiques : METRICS_DISABLE=1
# METRICS_LOG_INTERVAL_MS=15000
# METRICS_DISABLE=1

# APIs externes (clés à ne jamais committer — uniquement dans .env local)
# Giphy : https://developers.giphy.com/ — kill feed (GIFs)
# GIPHY_API_KEY=

# Rate limiting HTTP (routes /api/*) — fenêtre glissante
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=200
# RATE_LIMIT_PROXY_MAX=40
# RATE_LIMIT_METRICS_MAX=30

# Métriques : en production, exiger Authorization: Bearer <token> si défini
# METRICS_TOKEN=

# Confiance reverse proxy (1 = premier hop — Render / nginx)
# TRUST_PROXY=1
