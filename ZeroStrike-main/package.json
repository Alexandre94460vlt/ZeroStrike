{
  "name": "zero-strike",
  "version": "1.0.0",
  "description": "Jeu de tir tactique massivement multijoueur en local (40 joueurs)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "dev:display": "vite --config client-display/vite.config.js",
    "dev:mobile": "vite --config client-mobile/vite.config.js",
    "build:display": "vite build --config client-display/vite.config.js",
    "build:mobile": "vite build --config client-mobile/vite.config.js",
    "build:display:watch": "vite build --config client-display/vite.config.js --watch",
    "build:mobile:watch": "vite build --config client-mobile/vite.config.js --watch",
    "build:watch": "concurrently -c blue,magenta -n display,mobile \"npm run build:display:watch\" \"npm run build:mobile:watch\"",
    "spritesheet": "node scripts/make-spritesheet.js",
    "build": "npm run build:display && npm run build:mobile",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "test:watch": "node scripts/run-tests.mjs --watch",
    "test:e2e": "playwright test",
    "validate": "npm test && npm run build",
    "ci:local": "npm test && npm run build && npm run test:e2e",
    "tiled-to-ascii": "node scripts/tiled-to-ascii.mjs",
    "soutenance:pptx": "node scripts/build-soutenance-pptx.mjs"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "nipplejs": "^0.10.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/teko": "^5.2.7",
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.2.1",
    "phaser": "^3.70.0",
    "pptxgenjs": "^3.12.0",
    "sharp": "^0.33.0",
    "vite": "^7.3.1"
  }
}
